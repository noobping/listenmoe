msgid "Play %s"
msgstr "Reproducir %s"

msgid "About"
msgstr "Acerca de"

msgid "Connecting..."
msgstr "Conectando..."

msgid "Main Menu"
msgstr "Menú principal"

msgid "Quit"
msgstr "Salir"

msgid "Keyboard Shortcuts"
msgstr "Atajos de teclado"

msgid "General"
msgstr "General"

msgid "Playback"
msgstr "Reproducción"

msgid "Play or pause"
msgstr "Reproducir o pausar"

msgid "Stop playback"
msgstr "Detener reproducción"

msgid "Copy current track"
msgstr "Copiar pista actual"

msgid "Stations"
msgstr "Emisoras"

msgid "Play J-POP"
msgstr "Reproducir J-POP"

msgid "Play K-POP"
msgstr "Reproducir K-POP"

msgid "Previous station"
msgstr "Emisora anterior"

msgid "Next station"
msgstr "Siguiente emisora"

msgid "Window"
msgstr "Ventana"

msgid "Open preferences"
msgstr "Abrir preferencias"

msgid "Show shortcuts"
msgstr "Mostrar atajos"

msgid "Preferences"
msgstr "Preferencias"

msgid "Startup Defaults"
msgstr "Valores predeterminados de inicio"

msgid "Default station"
msgstr "Emisora predeterminada"

msgid "J-POP"
msgstr "J-POP"

msgid "K-POP"
msgstr "K-POP"

msgid "Autoplay"
msgstr "Reproducción automática"

msgid "Start playing automatically on launch"
msgstr "Iniciar la reproducción automáticamente al abrir la aplicación"

msgid "Enable pause and resume"
msgstr "Activar pausa y reanudación"

msgid "Use pause and resume for the main playback button"
msgstr "Usar pausa y reanudación para el botón principal de reproducción"

msgid "Discord Rich Presence"
msgstr "Rich Presence de Discord"

msgid "Enable Discord Rich Presence at runtime"
msgstr "Activar Rich Presence de Discord en tiempo de ejecución"

msgid "It is time to ditch other radios. Stream and metadata provided by LISTEN.moe."
msgstr "Es hora de dejar atrás otras radios. El stream y los metadatos son proporcionados por LISTEN.moe."

msgid "J-POP and K-POP radio"
msgstr "Radio de J-POP y K-POP"

msgid "Listen to J-POP and K-POP"
msgstr "Escucha J-POP/K-POP"

msgid "Pause and resume the live stream"
msgstr "Pausa y reanuda la transmisión en vivo"

msgid "Animated sound bars that react to the music"
msgstr "Barras de sonido animadas que reaccionan a la música"

msgid "Dynamic colors based on the current album or artist cover"
msgstr "Colores dinámicos basados en la portada del álbum o del artista actual"

msgid "No ads"
msgstr "Sin anuncios"

msgid "Initial release."
msgstr "Lanzamiento inicial."

msgid "When connected and there is no album or artist image"
msgstr "Conectado cuando no hay imagen del álbum o del artista"

msgid "Colored window when connected"
msgstr "Ventana con color cuando está conectado"

msgid "AI translation (GPT-5.2); reviewed by nobody"
msgstr "Traducción por IA (GPT-5.2); revisada por Kana"

msgid "This release focuses on visuals and localization."
msgstr "Esta versión se centra en mejoras visuales y localización."

msgid "Fine-tuned dark/light mode detection so light colors are no longer mistaken for dark ones."
msgstr "Se ajustó la detección del modo claro/oscuro para que los colores claros ya no se confundan con oscuros."

msgid "Polished translations and improved how they are applied."
msgstr "Se mejoraron las traducciones y la forma en que se aplican."

msgid "Removed gaps between sound bars."
msgstr "Se eliminaron los espacios entre las barras de sonido."

msgid "Streaming logic now better handles connection issues and stream changes."
msgstr "La lógica de transmisión ahora gestiona mejor los problemas de conexión y los cambios de transmisión."

msgid "Clarified the application description."
msgstr "Se aclaró la descripción de la aplicación."

msgid "Translated image captions"
msgstr "Subtítulos de imágenes traducidos"

msgid "Updated screenshots to use a more reasonable window size"
msgstr "Capturas de pantalla actualizadas para usar un tamaño de ventana más razonable"

msgid "Updated application icon"
msgstr "Icono de la aplicación actualizado"

msgid "Display the application icon in media controls."
msgstr "Mostrar el icono de la aplicación en los controles multimedia."

msgid "Optional Discord activity sharing"
msgstr "Uso compartido opcional de actividad en Discord"

msgid "Added Discord activity sharing."
msgstr "Se añadió el uso compartido de actividad en Discord."

msgid "Reconnect to Discord instead of disabling this feature."
msgstr "Se vuelve a conectar a Discord en lugar de desactivar esta función."

msgid "Added flags to control pause behavior, autoplay, or disable Discord integration."
msgstr "Se añadieron flags para controlar el comportamiento de pausa, el autoplay o desactivar la integración con Discord."

msgid "Fixed an issue where paused playback resumed during a network disruption."
msgstr "Se corrigió un problema en el que la reproducción en pausa se reanudaba durante una interrupción de red."

msgid "Added preferences and keyboard shortcuts."
msgstr "Se añadieron preferencias y atajos de teclado."

msgid "Changed pause, resume, and station switching behavior."
msgstr "Se cambió el comportamiento de pausar, reanudar y cambiar de emisora."

msgid "Added startup options for pause/resume or stop behavior, with play/stop now the default."
msgstr "Se añadieron opciones de inicio para pausa/reanudación o para el modo detener, y reproducir/detener ahora es el comportamiento predeterminado."
